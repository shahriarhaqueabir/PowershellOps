# .gitignore — PowershellOps Hybrid PowerShell Profile

# ─────────────────────────────────────────────
# AUTO-GENERATED REPORTS & TEST ARTEFACTS
# ─────────────────────────────────────────────
Reports/
testResults.xml
ops-test-results.xml

# ─────────────────────────────────────────────
# LOCAL CONTEXT & MEMORY
# ─────────────────────────────────────────────
docs/
Memory/
AI/TestMemory/
.idea/
.vscode/

# ─────────────────────────────────────────────
# POWERSHELL MODULE HELP CACHE
# ─────────────────────────────────────────────
Help/
Help/**/*.xml
Help/**/*.zip

# ─────────────────────────────────────────────
# INSTALLED SCRIPT METADATA (PSResourceGet)
# ─────────────────────────────────────────────
Scripts/InstalledScriptInfos/

# ─────────────────────────────────────────────
# THIRD-PARTY / VENDORED MODULES
# These should be installed via Install-OpsPrerequisite
# ─────────────────────────────────────────────
Modules/*/
!Modules/PowershellOps/

# ─────────────────────────────────────────────
# SECRETS & CREDENTIALS
# ─────────────────────────────────────────────
*.key
*.pem
*.pfx
*.crt
*.p12
.env
.env.*
secrets.*
credentials.*

# ─────────────────────────────────────────────
# BACKUP, LEGACY & DEV ARTEFACTS
# ─────────────────────────────────────────────
BackupOriginal/
Scripts/dev/
__final_check.ps1
*.backup.ps1
*.bak
*.old
*.tmp
*.temp
*.log

# ─────────────────────────────────────────────
# EDITOR & OS NOISE
# ─────────────────────────────────────────────
*.code-workspace
*.swp
*.swo
*~
Thumbs.db
Desktop.ini
.DS_Store
nul

